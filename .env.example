# Vercel CDN Configuration
# All images are automatically cached and served from Vercel's global CDN

# Google Apps Script URL for the contact/inquiry form
# Add this in your Vercel project settings under Environment Variables
PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# YOCO Payment Integration
# Get your keys from the YOCO merchant portal: https://portal.yoco.co.za
YOCO_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
YOCO_SECRETE_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
