---
import ContactForm from '../components/forms/ContactForm.astro';
import Layout from '../layouts/Page.astro';
import { Container } from '@components/odyssey-theme';

const seo = {
	title: 'Contact | Experience Africa Safaris',
	description:
 		'Get in touch with Experience Africa Safaris for bookings, enquiries, partnerships, or media. Use the form or contact details to reach our team.',
};
---

<Layout {seo}>
	<Container>
		<section class="contact-hero__section">
			<div class="contact-hero__text-section">
				<h1>Contact Us</h1>
				<p>
					Please reach out to us through this contact form or alternatively any
					of the channels below.
				</p>
			</div>
			<div class="col-2__container">
				<ContactForm />
			</div>
		</section>
	</Container>
	<Container>
		<section class="contact-cta__section">
			<h2>Find us elsewhere</h2>

			<div class="contact-cta__grid">
				<a
					href="https://www.tiktok.com/@curt_is_wild"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>TikTok</h3>
					<p>@curt_is_wild</p>
				</a>

				<a
					href="https://www.instagram.com/theexperienceafrica/"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>Instagram</h3>
					<p>@theexperienceafrica</p>
				</a>

				<a
					href="https://www.facebook.com/Thexperienceafrica"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>Facebook</h3>
					<p>@Thexperienceafrica</p>
				</a>

				<a
					href="https://www.youtube.com/Theexperienceafrica/featured"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>Youtube</h3>
					<p>@Theexperienceafrica</p>
				</a>

				<a href="mailto:curteis@experienceafrica.co.za" class="contact-cta__card">
					<h3>Email</h3>
					<p>curteis@experienceafrica.co.za</p>
				</a>

				<a
					href="https://wa.me/27715561035"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>WhatsApp</h3>
					<p>+27647388344</p>
				</a>
				<a
					href="tel:+27647388344"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta__card"
				>
					<h3>Phone</h3>
					<p>+27647388344</p>
				</a>
			</div>
		</section>
	</Container>
</Layout>

<style>
	.contact-hero__section {
		margin: var(--section-margin) auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: calc(90vh - var(--navbar-height));
		gap: 3rem;
	}
	.contact-hero__text-section {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background-color: var(--theme-surface-1);
		border-radius: var(--theme-shape-radius);
	}
	.col-2__container {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	@media (max-width: 768px) {
		.contact-hero__section {
			grid-template-columns: 1fr;
		}
	}
	.contact-cta__section {
		margin: var(--section-margin) auto;
		text-align: center;
	}

	.contact-cta__section h2 {
		margin-block: 2rem;
	}

	.contact-cta__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.contact-cta__card {
		padding: 2rem;
		background-color: var(--theme-surface-2);
		border-radius: var(--theme-shape-radius);
		text-decoration: none;
		color: var(--theme-on-surface-2);
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.contact-cta__card:hover {
		transform: translateY(-4px);
		box-shadow: var(--theme-shadow-md);
	}

	.contact-cta__card h3 {
		margin: 0;
	}

	.contact-cta__card p {
		margin: 0;
		opacity: 0.8;
		font-size: 0.95rem;
	}

	@media (max-width: 1024px) {
		.contact-cta__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.contact-cta__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
