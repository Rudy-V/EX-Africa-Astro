---
import {
	Container,
	FeatureCard,
	TextCardSection,
	StickyTextImageSection,
} from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/sections/heros/HeroSection.astro';
import ContactForm from '../components/forms/ContactForm.astro';

const seo = {
	title: 'Locations | Astro Odyssey Theme',
	description: 'Operating locations',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<h1>Safaris by Experience Africa Safaris</h1>
			<p>
				Browse our pre-planned packages or learn how to build your own
				adventure.
			</p>
		</div>
		<picture slot="image-container">
			<img
				src="assets/images/home/Camping.webp"
				alt="Experience Africa Safaris Camping picture"
				id="home-hero-image"
			/>
		</picture>
	</HeroSection>
	<Container>
		<section class="feature-card__section">
			<div class="feature-card__grid">
				<FeatureCard
					href="#packages"
					title="Safari packages"
					imgSrc="assets/images/home/screenshots/HoneyguideRnager-3"
				/>
				<FeatureCard
					href="#custom"
					title="Build your own safari"
					imgSrc="/assets/images/home/screenshots/EAS"
				/>
			</div>
		</section>
	</Container>
	<Container>
		<TextCardSection>
			<h2 id="packages">Safari packages</h2>
			<strong>Unforgettable encounters, seamlessly planned for you</strong>
		</TextCardSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>Rare bird & wildlife photographic safari</h3>
				<h4>Starting from R9000 per person per night</h4>
				<p>
					Embark on an exclusive photographic safari crafted for discerning
					adventurers who seek both rare encounters and refined comfort. Each
					day invites you deeper into southern Africa’s wild heart, where
					vibrant, elusive bird species share the stage with elephants, big
					cats, and other majestic wildlife. Guided by seasoned trackers and
					photographic experts, you’ll be perfectly positioned to capture
					once-in-a-lifetime shots against breathtaking backdrops of golden
					savannas and untamed wilderness. After a day of exploration, retreat
					to elegant accommodations where luxury and tranquillity blend
					seamlessly with the rhythms of the wild, ensuring every moment of your
					journey is as memorable as the images you take home.
				</p>
			</div>
			<picture slot="image-container">
				<img
					src="public/assets/images_converted/Website-73.webp"
					alt="Lion in the Kruger"
					loading="lazy"
				/>
			</picture>
		</StickyTextImageSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>Eco Safaris: hands-on-conservation</h3>
				<h4>Starting from R9000 per person per night</h4>
				<p>
					Step into an extraordinary safari where adventure meets purpose.
					Designed for travelers who seek more than just breathtaking
					encounters, this journey allows you to connect deeply with Africa’s
					wilderness while supporting vital conservation efforts. Each day
					reveals the beauty of rare wildlife and pristine landscapes, offering
					unforgettable moments that inspire both wonder and responsibility. At
					night, retreat to luxurious eco-lodges that blend comfort with
					sustainability, ensuring your experience is as indulgent as it is
					meaningful.
				</p>
			</div>
			<picture slot="image-container">
				<img
					src="/assets/images_converted/Nature (20 of 15).webp"
					alt="Lion in the Kruger"
					loading="lazy"
				/>
			</picture>
		</StickyTextImageSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>Overland safari</h3>
				<h4>Starting from R9000 per person per night</h4>
				<p>
					An overland safari is an adventurous journey in a specially equipped
					vehicle, a custom-built Land Cruiser safari truck. It's about the
					journey itself, crossing diverse landscapes and visiting multiple
					countries. It's a more rugged, immersive style of travel compared to a
					traditional safari, with a focus on group participation and
					experiencing the continent first-hand.
				</p>
			</div>
			<picture slot="image-container">
				<img
					src="/assets/images_converted/house  (10 of 14).webp"
					alt="Lion in the Kruger"
					loading="lazy"
				/>
			</picture>
		</StickyTextImageSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>Mixed lodge safari</h3>
				<h4>Starting from R9000 per person per night</h4>
				<p>
					This type of safari offers a blend of accommodation styles. You will
					stay in a combination of basic or mid-range lodges, comfortable tented
					camps, and even some camping. This allows for a more varied and
					flexible experience, combining the comfort of a bed and private
					bathroom with the authenticity of a true bush camping experience.
				</p>
			</div>
			<picture slot="image-container">
				<img
					src="/assets/images_converted/Zimbabwe EAS (23 of 35).webp"
					alt="Lion in the Kruger"
					loading="lazy"
				/>
			</picture>
		</StickyTextImageSection>
	</Container>
	<Container>
		<TextCardSection>
			<h2 id="custom">Private/Custom Safaris</h2>
			<strong>Build the safari of your dreams with our expert guidance</strong>
		</TextCardSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>Decide on the location for your safari</h3>
				<p>
					<strong>South Africa - </strong>Accessible and diverse, with the
					Kruger National Park and numerous private reserves.
				</p>
				<p>
					<strong>Botswana - </strong>Known for the Okavango Delta and Chobe,
					offering water-based and land safaris.
				</p>
				<p>
					<strong>Namibia - </strong>Unique desert-adapted wildlife and striking
					landscapes.
				</p>
				<p>
					<strong>Zimbabwe - </strong>Rich game viewing, plus Victoria Falls as
					a dramatic highlight.
				</p>
			</div>
			<picture slot="image-container">
				<img
					src="/assets/images_converted/Zimbabwe EAS (23 of 35).webp"
					alt="Lion in the Kruger"
					loading="lazy"
				/>
			</picture>
		</StickyTextImageSection>
	</Container>
	<Container>
		<StickyTextImageSection>
			<div slot="text-container">
				<h3>
					Decide whether you're camping, glamping or staying in a luxury lodge
				</h3>
			</div>
		</StickyTextImageSection>
	</Container>
</Layout>

<style>
	.feature-card__section {
		margin: var(--section-margin) auto;
	}
	.feature-card__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--theme-grid-gap);
	}
	@media (max-width: 768px) {
		.feature-card__grid {
			grid-template-columns: 1fr;
		}
	}
	.contact-hero__section {
		margin: var(--section-margin) auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: calc(90vh - var(--navbar-height));
		gap: 3rem;
	}
	.contact-hero__text-section {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background-color: var(--theme-surface-2);
		border-radius: var(--theme-shape-radius);
	}
	.col-2__container {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	@media (max-width: 768px) {
		.contact-hero__section {
			grid-template-columns: 1fr;
		}
	}
</style>
