---
import {
	Container,
	YouTubeEmbedSection,
	FeatureCard,
} from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/sections/heros/HeroSection.astro';
import TextCardSection from '../components/sections/TextCardSection.astro';
import GetStartedSection from '../components/sections/GetStartedSection.astro';

const seo = {
	title: 'About | Experience Africa Safaris',
	description:
 		'Meet Curteis Roberts — founder, photographer and safari specialist behind Experience Africa Safaris. Learn about our philosophy, expertise and journey.',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<h1>About Curteis Roberts</h1>
			<p>
				Born in Dundee, KwaZulu-Natal, South Africa, Curteis has cultivated a
				lifelong bond with the wild, fostered by early visits to game reserves
				and extensive global travel since childhood.
			</p>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/home/Me Wildife Camera.webp"
				alt="Curteis Roberts"
				id="home-hero-image"
			/>
		</picture>
	</HeroSection>
	<Container>
		<TextCardSection>
			<h2>Passion for Photography and Storytelling</h2>
			<p>
				He is a passionate photographer and content creator who began his
				journey at 14. He has since explored 22 countries, capturing the world
				through his lens. Curteis uniquely blends his enthusiasm for
				storytelling with a deep understanding of technology and photography.
			</p>
			<p>
				An avid fisherman, hiker, and storyteller, Curteis is dedicated to
				sharing the beauty and adventure of Southern Africa with the world.
			</p>
		</TextCardSection>
	</Container>
	<Container>
		<YouTubeEmbedSection
			url="https://www.youtube.com/watch?v=QUWt3vyyViM"
			rounded
		/>
	</Container>
	<Container>
		<section class="feature-card__section">
			<h2>Extensive Hospitality Experience</h2>
			<p>
				With over eight years in hospitality, Curteis has experience in diverse
				roles—guide, cook, barman, waiter, and porter—from luxurious 5-star
				African lodges to simple camping under the stars.
			</p>
			<div class="feature-card__grid">
				<FeatureCard
					href="/safaris"
					title="View safaris"
					imgSrc="/assets/images/home/screenshots/LionBoard"
				/>
				<FeatureCard
					href="/locations"
					title="View locations"
					imgSrc="/assets/images/home/screenshots/Serengeti-A7IV-Photos"
				/>
			</div>
		</section>
	</Container>
	<Container>
		<TextCardSection>
			<h2>Founder of Experience Africa Safaris</h2>
			<p>
				His expertise ultimately led him to establish <strong
					>Experience Africa Safaris</strong
				>, a bespoke travel company specializing in authentic, personalized
				experiences across Southern Africa.
			</p>
		</TextCardSection>
	</Container>
	<Container>
		<GetStartedSection />
	</Container>
</Layout>

<style>
	.feature-card__section {
		margin: var(--section-margin) auto;
	}
	.feature-card__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--theme-grid-gap);
	}
	@media (max-width: 768px) {
		.feature-card__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
